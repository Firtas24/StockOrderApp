@model StockOrderApp.Models.Order



<div class="mb-3">
    <strong>Durum:</strong>
    @{
        string badge = Model.Status switch
        {
            "Hazırlanıyor" => "bg-warning text-dark",
            "Kargoya Verildi" => "bg-info text-dark",
            "Tamamlandı" => "bg-success",
            "İptal" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    <span class="badge @badge">@Model.Status</span>
</div>

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-0">Sipariş Detayı #@Model.Id</h2>
        <div class="text-muted">
            @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
        </div>
    </div>

    <a class="btn btn-outline-secondary"
       asp-area="Admin" asp-controller="Orders" asp-action="Index">Geri</a>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Teslimat Bilgileri</h5>
                <div><strong>Ad Soyad:</strong> @Model.FullName</div>
                <div><strong>Telefon:</strong> @Model.Phone</div>
                <div><strong>Adres:</strong> @Model.Address</div>
                @if (!string.IsNullOrWhiteSpace(Model.Note))
                {
                    <div class="mt-2"><strong>Not:</strong> @Model.Note</div>
                }
                <hr />
                <div><strong>UserId:</strong> @Model.UserId</div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ürün</th>
                            <th style="width:120px;" class="text-end">Birim</th>
                            <th style="width:90px;" class="text-center">Adet</th>
                            <th style="width:140px;" class="text-end">Tutar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in Model.Items)
                        {
                            <tr>
                                <td>@(i.Product?.Name ?? $"Ürün #{i.ProductId}")</td>
                                <td class="text-end">@i.UnitPrice.ToString("0.00") ₺</td>
                                <td class="text-center">@i.Quantity</td>
                                <td class="text-end"><strong>@i.LineTotal.ToString("0.00") ₺</strong></td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Toplam</th>
                            <th class="text-end">@Model.Total.ToString("0.00") ₺</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
