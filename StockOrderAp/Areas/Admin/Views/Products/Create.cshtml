@model StockOrderApp.Models.Product
@{
    ViewData["Title"] = "Yeni Ürün";
}

<h2 class="mb-3">Yeni Ürün</h2>

<form asp-area="Admin" asp-controller="Products" asp-action="Create" method="post" class="row g-3" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="col-md-6">
        <label class="form-label">Ürün Görseli</label>
        <input type="file" name="imageFile" class="form-control" accept="image/*" />
        <div class="form-text">Opsiyonel. Boş bırakabilirsin.</div>
    </div>

    <div class="col-md-6">
        <label class="form-label">Ürün Adı</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label class="form-label">Fiyat</label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="col-md-3">
        <label class="form-label">Stok</label>
        <input asp-for="Stock" class="form-control" type="number" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label class="form-label">Kategori</label>
        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList">
            <option value="">Seçiniz</option>
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- ✅ AKTİF / PASİF -->
    <div class="col-12">
        <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">Aktif Ürün</label>
        </div>
        <div class="form-text">
            Kapalıysa kullanıcı tarafında görünmez ve ana sayfa önerilerine girmez.
        </div>
        <span asp-validation-for="IsActive" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Kaydet</button>
        <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Products" asp-action="Index">Geri</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
