@model List<StockOrderApp.Models.Product>

@{
    ViewData["Title"] = "Ürünler";
    var searchText = ViewBag.Search as string;
}

<h2 class="mb-0">Ürünler</h2>
<div class="text-muted mb-3">Ürünleri görüntüle, düzenle ve sil.</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-6">
        <input name="search"
               value="@searchText"
               class="form-control"
               placeholder="Ürün veya kategori ara..." />
    </div>

    <div class="col-md-2">
        <button class="btn btn-dark w-100" type="submit">Ara</button>
    </div>

    <div class="col-md-2">
        <a class="btn btn-outline-secondary w-100"
           asp-area="Admin"
           asp-controller="Products"
           asp-action="Index">
            Temizle
        </a>
    </div>

    <div class="col-md-2 text-end">
        <a class="btn btn-primary w-100"
           asp-area="Admin"
           asp-controller="Products"
           asp-action="Create">
            + Yeni Ürün
        </a>
    </div>
</form>

<div class="text-muted mb-2">
    @(Model?.Count ?? 0) kayıt listelendi
    @if (!string.IsNullOrWhiteSpace(searchText))
    {
        <span> | Arama: "<strong>@searchText</strong>"</span>
    }
</div>

@if (TempData["success"] != null)
{
    <div id="toastSuccess" class="alert alert-success">
        @TempData["success"]
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:10%;">Görsel</th>
                    <th style="width:25%;">Ürün</th>
                    <th style="width:20%;">Kategori</th>
                    <th style="width:15%;">Fiyat</th>
                    <th style="width:10%;">Stok</th>
                    <th style="width:20%;" class="text-end">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="p-4 text-center text-muted">
                            @if (!string.IsNullOrWhiteSpace(searchText))
                            {
                                <span>Aramaya uygun ürün bulunamadı.</span>
                            }
                            else
                            {
                                <span>Henüz ürün yok.</span>
                            }
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                @if (!string.IsNullOrWhiteSpace(p.ImagePath))
                                {
                                    <img src="@p.ImagePath"
                                         alt="ürün görseli"
                                         style="width:56px;height:56px;object-fit:cover;border-radius:12px;border:1px solid rgba(0,0,0,.08);" />
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>

                            <td class="align-middle fw-semibold">@p.Name</td>

                            <td class="align-middle">
                                @(@p.Category?.Name ?? "-")
                            </td>

                            <td class="align-middle">
                                @($"{p.Price:N2} ₺")
                            </td>

                            <td class="align-middle">
                                @{
                                    var stock = p.Stock;
                                    var badge = stock == 0 ? "bg-danger"
                                    : stock <= 5 ? "bg-warning text-dark"
                                    : "bg-success";
                                    var label = stock == 0 ? "Yok"
                                    : stock <= 5 ? "Az"
                                    : "Var";
                                }
                                <span class="badge @badge">@label (@stock)</span>
                            </td>

                            <td class="align-middle text-end">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-area="Admin"
                                   asp-controller="Products"
                                   asp-action="Edit"
                                   asp-route-id="@p.Id">
                                    Düzenle
                                </a>

                                <form asp-area="Admin"
                                      asp-controller="Products"
                                      asp-action="Delete"
                                      asp-route-id="@p.Id"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Silmek istediğine emin misin?');">
                                        Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var el = document.getElementById("toastSuccess");
        if (!el) return;
        setTimeout(function () { el.remove(); }, 2200);
    });
</script>
