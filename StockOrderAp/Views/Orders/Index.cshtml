@model List<StockOrderApp.Models.Order>
@using StockOrderApp.Helpers

@{
    ViewData["Title"] = "Siparişlerim";

    string BadgeClass(string? status) => status switch
    {
        OrderStatus.Preparing => "bg-warning text-dark",
        OrderStatus.Shipped => "bg-info text-dark",
        OrderStatus.Completed => "bg-success",
        OrderStatus.Canceled => "bg-danger",
        _ => "bg-secondary"
    };
}

<h2 class="mb-2">Siparişlerim</h2>
<div class="text-muted mb-3">Geçmiş siparişlerini buradan görüntüleyebilirsin.</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-light border">Henüz siparişin yok.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:90px;">#</th>
                        <th style="width:180px;">Tarih</th>
                        <th style="width:170px;">Durum</th>
                        <th class="text-end" style="width:220px;">Toplam</th>
                        <th class="text-end" style="width:120px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var shownTotal = (o.GrandTotal > 0 ? o.GrandTotal : o.Total);

                        <tr>
                            <td class="align-middle">#@o.Id</td>
                            <td class="align-middle">@o.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>

                            <td class="align-middle">
                                <span class="badge @BadgeClass(o.Status)">@o.Status</span>
                            </td>

                            <td class="align-middle text-end">
                                <div class="fw-semibold">@shownTotal.ToString("N2") ₺</div>

                                @if (!string.IsNullOrWhiteSpace(o.CouponCode) && o.DiscountTotal > 0)
                                {
                                    <div class="small text-muted">
                                        Kupon: @o.CouponCode (-@o.DiscountTotal.ToString("N2") ₺)
                                    </div>
                                }
                            </td>

                            <td class="align-middle text-end">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id">
                                    Detay
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
