@model StockOrderApp.Models.Product
@using StockOrderApp.Models

@{
    ViewData["Title"] = Model.Name;

    var reviews = ViewBag.Reviews as List<ProductReview> ?? new();
    double avg = 0.0;
    if (ViewBag.AvgRating != null)
    {
        avg = (double)ViewBag.AvgRating;
    }
}

<div class="d-flex align-items-start justify-content-between mb-3">
    <div>
        <h2 class="mb-1">@Model.Name</h2>
        <div class="text-muted">Kategori: @Model.Category?.Name</div>
    </div>

    <a class="btn btn-outline-dark" asp-controller="Products" asp-action="Index">Ürünlere Dön</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="fs-5 fw-bold">@Model.Price.ToString("N2") ₺</div>
                <div class="text-muted">Stok: @Model.Stock</div>
            </div>

            <div class="text-end">
                @if (Model.Stock > 0)
                {
                    <a class="btn btn-success"
                       asp-controller="Cart"
                       asp-action="Add"
                       asp-route-id="@Model.Id">
                        Sepete Ekle
                    </a>
                }
                else
                {
                    <span class="text-danger fw-semibold">Stokta yok</span>
                }
            </div>
        </div>
    </div>
</div>

<!-- Rating Summary -->
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h5 class="mb-0">Yorumlar</h5>
                <div class="text-muted small">Kullanıcıların değerlendirmeleri</div>
            </div>

            <div class="text-end">
                <div class="fw-bold">Ortalama: @avg.ToString("0.0") / 5</div>
                <div class="text-muted small">@reviews.Count yorum</div>
            </div>
        </div>
    </div>
</div>
@{
    var related = ViewBag.RelatedProducts as List<StockOrderApp.Models.Product> ?? new();
}

@if (related.Any())
{
    <hr />
    <h5 class="mb-3">Benzer Ürünler</h5>

    <div class="row">
        @foreach (var p in related)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h6 class="mb-1">@p.Name</h6>
                        <div class="text-muted small mb-2">@p.Category?.Name</div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <strong>@p.Price.ToString("N2") ₺</strong>
                            <span class="small text-success">Stok: @p.Stock</span>
                        </div>

                        <a class="btn btn-outline-primary w-100"
                           asp-controller="Products"
                           asp-action="Details"
                           asp-route-id="@p.Id">
                            İncele
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}


@if (TempData["error"] != null)
{
    <div class="alert alert-danger border-0 rounded-4">@TempData["error"]</div>
}
@if (TempData["success"] != null)
{
    <div class="alert alert-success border-0 rounded-4">@TempData["success"]</div>
}

<!-- Add Review -->
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h6 class="mb-3">Yorum Yap</h6>

            <form asp-controller="Reviews" asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="productId" value="@Model.Id" />

                <div class="row g-2">
                    <div class="col-md-3">
                        <label class="form-label">Puan</label>
                        <select name="rating" class="form-select">
                            <option value="5">5 - Mükemmel</option>
                            <option value="4">4 - İyi</option>
                            <option value="3">3 - Orta</option>
                            <option value="2">2 - Kötü</option>
                            <option value="1">1 - Berbat</option>
                        </select>
                    </div>

                    <div class="col-md-9">
                        <label class="form-label">Yorum</label>
                        <textarea name="comment"
                              class="form-control"
                              rows="2"
                              maxlength="500"
                              placeholder="Ürün hakkındaki deneyimini yaz..."></textarea>
                        <div class="form-text">Maksimum 500 karakter.</div>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-dark" type="submit">Gönder</button>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-light border rounded-4">
        Yorum yapmak için giriş yapmalısın.
    </div>
}

<!-- Reviews List -->
@if (!reviews.Any())
{
    <div class="text-muted">Henüz yorum yok.</div>
}
else
{
    <div class="list-group">
        @foreach (var r in reviews)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <span class="badge bg-dark">@r.Rating / 5</span>
                    <span class="text-muted small">@r.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </div>
                <div>@r.Comment</div>
            </div>
        }
    </div>
}
