@model StockOrderApp.Models.UserProfile
@{
    ViewData["Title"] = "Profilim";
    var email = ViewBag.Email as string;
}

<h2 class="mb-2">Profilim</h2>
<div class="text-muted mb-3">Kişisel bilgilerini buradan güncelleyebilirsin.</div>

@if (TempData["success"] != null)
{
    <div class="alert alert-success">@TempData["success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">E-posta</label>
                    <input class="form-control" value="@email" disabled />
                    <div class="form-text">E-posta Identity tarafından yönetilir.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Ad Soyad</label>
                    <input asp-for="FullName" class="form-control" placeholder="Örn: Ali Veli" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">Telefon</label>
                    <input asp-for="Phone" class="form-control" placeholder="05xx..." />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label class="form-label">Adres</label>
                    <textarea asp-for="Address" class="form-control" rows="3" placeholder="Adres bilgisi..."></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">Kaydet</button>
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Anasayfa</a>
                <a class="btn btn-outline-dark" asp-area="Identity" asp-page="/Account/Manage/ChangePassword">Şifre Değiştir</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
